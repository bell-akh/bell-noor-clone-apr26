<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <!-- Shopify CDN – fonts & icons -->
  <link rel="preconnect" href="https://fonts.shopifycdn.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" />
  <link rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/web/assets/v1/vite/client/en/vendor-DlcN3w6l.js" crossorigin="anonymous" type="module" />
  <!-- Shopify CDN Polaris icons via unpkg mirror -->
  <link rel="stylesheet" href="/css/style.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : Date.now() %>" />
  <link rel="icon" href="https://www.belle-noor.in/cdn/shop/files/Png-06_70x.png?v=1749296443" />
</head>
<body>

<!-- ── Announcement Bar ── -->
<div class="announcement-bar">
  🔥 Get 20% OFF – Use Code: <strong>"BELL20"</strong>
</div>

<!-- ── Header ── -->
<header class="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="logo">
      <img src="https://www.belle-noor.in/cdn/shop/files/Png-06_70x.png?v=1749296443" alt="Belle Noor" />
    </a>

    <!-- Nav -->
    <nav class="main-nav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/collections/new-arrivals">New Arrivals</a></li>
        <li class="has-dropdown">
          <a href="/collections/women">Shop</a>
          <div class="dropdown">
            <div class="dropdown-inner">
              <div class="dropdown-col">
                <p class="dropdown-heading">Smart Casual</p>
                <a href="/collections/women-tops">Tops</a>
                <a href="/collections/women-bottoms">Bottoms</a>
                <a href="/collections/dresses">Dresses</a>
              </div>
              <div class="dropdown-col">
                <p class="dropdown-heading">Ethnic Essentials</p>
                <a href="/collections/kurti">Kurti</a>
                <a href="/collections/lehengas">Lehengas</a>
                <a href="/collections/festive">Festive</a>
              </div>
              <div class="dropdown-img">
                <img src="https://www.belle-noor.in/cdn/shop/files/WhatsApp_Image_2025-03-22_at_19.14.43_b1e5b0dd.jpg?v=1742649332" alt="Women's Collection" />
              </div>
            </div>
          </div>
        </li>
        <li><a href="/collections/festive">Festive</a></li>
        <li><a href="#about">About Us</a></li>
      </ul>
    </nav>

    <!-- Header Icons -->
    <div class="header-icons">
      <button class="icon-btn search-toggle" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <a href="/cart" class="icon-btn cart-link" aria-label="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %>
      </a>
      <button class="icon-btn mobile-menu-toggle" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Nav -->
<div class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-inner">
    <button class="mobile-nav-close">✕</button>
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/collections/new-arrivals">New Arrivals</a></li>
      <li><a href="/collections/women">Shop All</a></li>
      <li><a href="/collections/women-tops">Tops</a></li>
      <li><a href="/collections/dresses">Dresses</a></li>
      <li><a href="/collections/kurti">Kurti</a></li>
      <li><a href="/collections/lehengas">Lehengas</a></li>
      <li><a href="/collections/festive">Festive</a></li>
      <li><a href="#about">About Us</a></li>
    </ul>
  </div>
</div>
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>

<!-- Search Drawer -->
<div class="search-drawer" id="searchDrawer">
  <div class="search-drawer-inner">
    <form action="/collections/all" method="get">
      <input type="text" name="q" placeholder="Search products…" autofocus />
      <button type="submit">Search</button>
    </form>
    <button class="search-close">✕</button>
  </div>
</div>
