<%- include('partials/header') %>

<main>
  <section class="checkout-page">
    <h1>Checkout</h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="checkout-layout">
      <!-- Form -->
      <div class="checkout-form">
        <h2>Delivery Information</h2>
        <form action="/checkout" method="post">
          <div class="form-row">
            <div class="form-group">
              <label>Full Name *</label>
              <input type="text" name="name" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label>Email *</label>
              <input type="email" name="email" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-group">
            <label>Phone Number *</label>
            <input type="tel" name="phone" placeholder="+91 XXXXX XXXXX" required />
          </div>
          <div class="form-group">
            <label>Address *</label>
            <textarea name="address" rows="2" placeholder="House no., Street, Area" required></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>City *</label>
              <input type="text" name="city" required />
            </div>
            <div class="form-group">
              <label>State</label>
              <input type="text" name="state" />
            </div>
            <div class="form-group">
              <label>PIN Code *</label>
              <input type="text" name="pincode" maxlength="6" required />
            </div>
          </div>

          <h2>Payment Method</h2>
          <div class="payment-options">
            <label class="payment-opt">
              <input type="radio" name="payment" value="cod" checked />
              <span>Cash on Delivery</span>
            </label>
            <label class="payment-opt">
              <input type="radio" name="payment" value="upi" />
              <span>UPI / PhonePe / GPay</span>
            </label>
            <label class="payment-opt">
              <input type="radio" name="payment" value="card" />
              <span>Credit / Debit Card</span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary btn-lg btn-full">Place Order</button>
        </form>
      </div>

      <!-- Order Summary -->
      <div class="checkout-summary">
        <h2>Order Summary</h2>
        <div class="checkout-items">
          <% cart.items.forEach(item => { %>
            <div class="checkout-item">
              <div class="checkout-item-img-wrap">
                <img src="<%= item.product.images[0] %>" alt="<%= item.product.title %>" />
                <span class="checkout-item-badge"><%= item.qty %></span>
              </div>
              <div class="checkout-item-info">
                <p><%= item.product.title %></p>
                <small>Size: <%= item.size %></small>
              </div>
              <span>Rs. <%= formatPrice(item.product.price * item.qty) %></span>
            </div>
          <% }) %>
        </div>

        <div class="summary-divider"></div>
        <div class="summary-row">
          <span>Subtotal</span>
          <span>Rs. <%= formatPrice(total) %></span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span><%= total >= 99900 ? 'FREE' : 'Rs. 99.00' %></span>
        </div>
        <div class="summary-row summary-total">
          <span>Total</span>
          <span>Rs. <%= formatPrice(total >= 99900 ? total : total + 9900) %></span>
        </div>

        <div class="promo-block">
          <p>🔥 Use code <strong>BELL20</strong> for 20% OFF</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
