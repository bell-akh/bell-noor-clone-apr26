<%- include('partials/header') %>

<main>
  <div class="breadcrumb">
    <a href="/">Home</a> /
    <a href="/collections/all">All Products</a> /
    <span><%= product.title %></span>
  </div>

  <section class="product-page">
    <!-- Images -->
    <div class="product-images">
      <div class="product-main-img" id="mainImg">
        <img src="<%= product.images[0] %>" alt="<%= product.title %>" id="mainImgEl" />
      </div>
      <% if (product.images.length > 1) { %>
        <div class="product-thumbnails">
          <% product.images.forEach((img, i) => { %>
            <img src="<%= img %>" alt="<%= product.title %> <%= i+1 %>" class="thumb <%= i === 0 ? 'active' : '' %>" onclick="setMain('<%= img %>', this)" />
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Info -->
    <div class="product-info">
      <p class="product-vendor"><%= product.vendor %></p>
      <h1 class="product-title"><%= product.title %></h1>

      <div class="product-price-block">
        <span class="product-price">Rs. <%= formatPrice(product.price) %></span>
        <% if (product.comparePrice) { %>
          <span class="product-compare">Rs. <%= formatPrice(product.comparePrice) %></span>
          <span class="discount-badge">
            <%= Math.round((1 - product.price / product.comparePrice) * 100) %>% OFF
          </span>
        <% } %>
      </div>

      <% if (product.inStock) { %>
        <p class="in-stock">✓ In Stock</p>
      <% } else { %>
        <p class="out-of-stock">Out of Stock</p>
      <% } %>

      <form action="/cart/add" method="post" class="add-to-cart-form">
        <input type="hidden" name="productId" value="<%= product.id %>" />

        <div class="size-selector">
          <label>Size</label>
          <div class="size-options">
            <% product.sizes.forEach(size => { %>
              <label class="size-opt">
                <input type="radio" name="size" value="<%= size %>" required />
                <span><%= size %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="qty-selector">
          <label>Quantity</label>
          <div class="qty-control">
            <button type="button" onclick="adjustQty(-1)">−</button>
            <input type="number" name="qty" id="qtyInput" value="1" min="1" max="10" />
            <button type="button" onclick="adjustQty(1)">+</button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
        <a href="/checkout" class="btn btn-outline btn-lg">Buy it Now</a>
      </form>

      <div class="product-meta">
        <span>Type: <%= product.type %></span>
        <span>Vendor: <%= product.vendor %></span>
      </div>

      <!-- WhatsApp -->
      <a href="https://wa.me/917016416645?text=Hi!%20I%20have%20a%20question%20about%20<%= encodeURIComponent(product.title) %>" target="_blank" class="whatsapp-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        Chat on WhatsApp
      </a>

      <!-- Tabs -->
      <div class="product-tabs">
        <div class="tab-headers">
          <button class="tab-btn active" onclick="switchTab(this, 'desc')">Description</button>
          <button class="tab-btn" onclick="switchTab(this, 'details')">Details & Shipping</button>
        </div>
        <div class="tab-content active" id="tab-desc">
          <p><%= product.description %></p>
        </div>
        <div class="tab-content" id="tab-details">
          <ul>
            <% product.details.forEach(d => { %>
              <li><%= d %></li>
            <% }) %>
          </ul>
          <div class="shipping-info">
            <p>🚚 Free standard shipping on orders above ₹999</p>
            <p>📦 Processed within 1–2 business days</p>
            <p>🔄 Easy 7-day return or exchange policy</p>
            <p>💳 Cash on Delivery available</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <% if (related.length > 0) { %>
    <section class="section related-section">
      <h2 class="section-title">Related Products</h2>
      <div class="product-grid product-grid-4">
        <% related.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }) %>
      </div>
    </section>
  <% } %>
</main>

<script>
  function setMain(src, el) {
    document.getElementById('mainImgEl').src = src;
    document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }
  function adjustQty(delta) {
    const input = document.getElementById('qtyInput');
    const val = parseInt(input.value) + delta;
    if (val >= 1 && val <= 10) input.value = val;
  }
  function switchTab(btn, id) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + id).classList.add('active');
  }
</script>

<%- include('partials/footer') %>
